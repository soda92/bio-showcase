{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Django",
            "type": "debugpy",
            "request": "launch",
            "args": [
                "runserver",
                "9000"
            ],
            "django": true,
            "autoStartBrowser": false,
            "program": "${workspaceFolder}/manage.py",
            "console": "integratedTerminal"
        },
        {
            "name": "Deno Frontend",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/frontend/dev.ts",
            "cwd": "${workspaceFolder}/frontend",
            "runtimeExecutable": "deno",
            "runtimeArgs": [
                "run",
                "--inspect",
                "--allow-all",
                "--watch=static/,routes/,islands/,components/"
            ],
            "attachSimplePort": 9229,
            "console": "integratedTerminal"
        },
        {
            "name": "Update Version Script",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/update_version.py",
            "console": "integratedTerminal"
        },
        {
            "name": "bio_pm",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/manage.py",
            "args": [
                "runserver"
            ],
            "env": {
                "submodule": "bio_pm"
            },
            "console": "integratedTerminal"
        }
    ],
    "compounds": [
        {
            "name": "Django & Deno (Full Stack)",
            "configurations": [
                "Python Debugger: Django",
                "Deno Frontend"
            ]
        }
    ]
}